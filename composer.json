{
    "name": "ivanbaric/plans",
    "description": "SaaS plans, entitlements and synced usage for Laravel 13 applications.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "IvanBaric\\Plans\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IvanBaric\\Plans\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "IvanBaric\\Plans\\PlansServiceProvider"
            ],
            "aliases": {
                "Plan": "IvanBaric\\Plans\\Facades\\Plan"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
